# ──────────────────────────────────────────────
#  Retorp - .gitignore
# ──────────────────────────────────────────────

# ── Python / Backend ──────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
env/
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/

# Base de datos local (se genera automáticamente)
backend/netmonitor.db
backend/*.db

# Variables de entorno
.env
.env.local
*.env

# ── Flutter / Dart ────────────────────────────
# Dependencias (se instalan con flutter pub get)
frontend/netmonitor_app/.dart_tool/
frontend/netmonitor_app/.flutter-plugins
frontend/netmonitor_app/.flutter-plugins-dependencies
frontend/netmonitor_app/.packages
frontend/netmonitor_app/pubspec.lock

# Build outputs
frontend/netmonitor_app/build/

# Android generados
frontend/netmonitor_app/android/.gradle/
frontend/netmonitor_app/android/captures/
frontend/netmonitor_app/android/local.properties
frontend/netmonitor_app/android/GeneratedPluginRegistrant.java
frontend/netmonitor_app/android/app/debug/
frontend/netmonitor_app/android/app/profile/
frontend/netmonitor_app/android/app/release/
frontend/netmonitor_app/android/key.properties
*.keystore
*.jks

# iOS generados
frontend/netmonitor_app/ios/.symlinks/
frontend/netmonitor_app/ios/Flutter/App.framework
frontend/netmonitor_app/ios/Flutter/Flutter.framework
frontend/netmonitor_app/ios/Flutter/Flutter.podspec
frontend/netmonitor_app/ios/Flutter/Generated.xcconfig
frontend/netmonitor_app/ios/Flutter/ephemeral/
frontend/netmonitor_app/ios/Flutter/app.flx
frontend/netmonitor_app/ios/Flutter/app.zip
frontend/netmonitor_app/ios/Flutter/flutter_assets/
frontend/netmonitor_app/ios/ServiceDefinitions.json
frontend/netmonitor_app/ios/Runner/GeneratedPluginRegistrant.*
frontend/netmonitor_app/ios/Podfile.lock

# Windows generados por Flutter (se crean con flutter create --platforms=windows .)
frontend/netmonitor_app/windows/CMakeLists.txt
frontend/netmonitor_app/windows/runner/CMakeLists.txt
frontend/netmonitor_app/windows/runner/main.cpp
frontend/netmonitor_app/windows/runner/flutter_window.cpp
frontend/netmonitor_app/windows/runner/flutter_window.h
frontend/netmonitor_app/windows/runner/run_loop.cpp
frontend/netmonitor_app/windows/runner/run_loop.h
frontend/netmonitor_app/windows/runner/utils.cpp
frontend/netmonitor_app/windows/runner/utils.h
frontend/netmonitor_app/windows/runner/win32_window.cpp
frontend/netmonitor_app/windows/runner/win32_window.h
frontend/netmonitor_app/windows/flutter/

# macOS
frontend/netmonitor_app/macos/Flutter/GeneratedPluginRegistrant.swift
frontend/netmonitor_app/macos/Flutter/ephemeral/

# Linux
frontend/netmonitor_app/linux/flutter/

# Web
frontend/netmonitor_app/web/

# ── Distribución / Releases ───────────────────
dist/
*.exe
*.apk
*.aab
*.ipa
RetorpSetup*.exe

# ── Sistema operativo ─────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDEs ──────────────────────────────────────
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.iml

# ── Logs ─────────────────────────────────────
*.log
npm-debug.log*
